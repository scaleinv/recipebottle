# Recipe Bottle Federation Regime — one foedus's provider-side IdP trust (RBSRF).
# This foedus IS a provider under the manor's ONE workforce pool; the pool
# identity itself (org, pool id, session duration) is manor-level and lives in
# rbmm_moorings/rbrw.env (RBSRW), not here. Carries no secrets — every value is a
# public identifier — so it ships committed.
#
# Seeded to the STANDING SPIKE TRUST (the project's standing test trust, per the
# federation-legs-spike findings). Affiance rewrites these values when founding a
# fresh provider against a real IdP tenant.

# Provider identity — this foedus's external OIDC provider under the manor's one
# pool (the pool coordinates live in rbmm_moorings/rbrw.env, RBSRW).
RBRF_PROVIDER_ID=

# Token-acquisition mechanism: this is the interactive (human device-flow) trust.
# Gates which IdP-trust fields apply — interactive carries the device endpoints
# and scope below; the programmatic (uploaded-JWKS) group stays closed.
RBRF_MECHANISM=rbnfe_interactive

# IdP trust — the external OIDC provider affianced to the manor (here: a free
# Microsoft Entra tenant). The endpoints are explicit fields, not derived from a
# tenant template, so a non-Entra IdP needs no code change — only new values.
RBRF_IDP_ISSUER=
RBRF_IDP_CLIENT_ID=

# Device-flow scope. Must request openid; must NOT request offline_access — a
# refresh token would let a run begin outside a live sitting (the human-present
# premise). The regime validator enforces both.
RBRF_IDP_SCOPE="openid profile email"

# Leg-1 device authorization endpoints (RFC 8628): the devicecode request and
# the token-polling endpoint.
RBRF_IDP_DEVICE_ENDPOINT=
RBRF_IDP_TOKEN_ENDPOINT=

# Workforce provider attribute mapping (affiance writes it into the provider).
# Must map google.subject; here the immutable Entra object id is the subject.
RBRF_ATTRIBUTE_MAPPING="google.subject=assertion.oid"

# eof
