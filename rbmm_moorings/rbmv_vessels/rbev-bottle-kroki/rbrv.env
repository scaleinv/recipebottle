# Recipe Bottle Regime Vessel - Bottle Kroki-core (Binding)

# Core Identity
RBRV_SIGIL=rbev-bottle-kroki
RBRV_DESCRIPTION="Kroki-core diagram render server (graphviz, plantuml, d2)"

# Vessel Mode
RBRV_VESSEL_MODE=rbnve_bind

# Egress Mode
RBRV_EGRESS_MODE=rbnve_tether

# Tool Image Reliquary
RBRV_RELIQUARY=

# Binding Configuration
# Version tag retained for legibility, digest-pinned per the bind => digest
# invariant (RBSRV): the @sha256: index digest captures the whole multi-arch
# manifest list, so the mirror copies the full list and the resulting GAR
# hallmark is digest-locked.
RBRV_BIND_IMAGE="docker.io/yuzutech/kroki:0.31.0@sha256:c16303ecd8ae840a6e3a76efa53468836c6297eeb7b7316845c3b24e8dbd0398"

# eof
