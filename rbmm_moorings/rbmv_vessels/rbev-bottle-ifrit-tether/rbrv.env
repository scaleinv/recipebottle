# Recipe Bottle Regime Vessel - Bottle Ifrit (Tethered Conjure)

# Core Identity
RBRV_SIGIL=rbev-bottle-ifrit-tether
RBRV_DESCRIPTION="Rust ifrit attack binary with network tools and echo service (tethered)"
RBRV_USER=ifrit

# Vessel Mode
RBRV_VESSEL_MODE=rbnve_conjure

# Egress Mode
RBRV_EGRESS_MODE=rbnve_tether

# Tool Image Reliquary
RBRV_RELIQUARY=

# Conjuring Configuration — shared build context with airgap variant
RBRV_CONJURE_DOCKERFILE="${RBRR_VESSEL_DIR}/common-ifrit-context/Dockerfile.tether"
RBRV_CONJURE_BLDCONTEXT="${RBRR_VESSEL_DIR}/common-ifrit-context"
RBRV_CONJURE_PLATFORMS="linux/amd64 linux/arm64"

# Base Images (ARG/FROM pattern — resolved by Foundry at conjure time)
RBRV_IMAGE_1_ORIGIN=rust:slim-bookworm
RBRV_IMAGE_1_ANCHOR=

# eof
