# Recipe Bottle Regime Vessel - Bottle fdkyclk (Conjuring)
# Keycloak OIDC server — the synthetic federation test IdP. Mints the
# programmatic-arm OIDC id_token the federation test rig exchanges at GCP STS.

# Core Identity
RBRV_SIGIL=rbev-bottle-fdkyclk
RBRV_DESCRIPTION="Keycloak OIDC server — synthetic federation test IdP (programmatic-arm token minter)"

# Vessel Mode
RBRV_VESSEL_MODE=rbnve_conjure

# Egress Mode
RBRV_EGRESS_MODE=rbnve_tether

# Tool Image Reliquary
RBRV_RELIQUARY=

# Conjuring Configuration
RBRV_CONJURE_DOCKERFILE="${RBRR_VESSEL_DIR}/${RBRV_SIGIL}/Dockerfile"
RBRV_CONJURE_BLDCONTEXT="${RBRR_VESSEL_DIR}/${RBRV_SIGIL}"
RBRV_CONJURE_PLATFORMS="linux/amd64 linux/arm64"

# Base Images (ARG/FROM pattern — resolved by Foundry at conjure time).
# Direct upstream pass-through: ANCHOR empty pulls straight from quay (the
# dominant vessel precedent). When Lode-time comes, fill ANCHOR with the
# ensconced GAR ref — the Dockerfile never changes.
RBRV_IMAGE_1_ORIGIN=quay.io/keycloak/keycloak:26.6.3@sha256:5fdbf2dbb5897cc34e82de49d13e23db011f9925089dbc555fc095f2c8bc1dac
RBRV_IMAGE_1_ANCHOR=

# eof
