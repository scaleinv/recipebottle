# Recipe Bottle Nameplate - fdkyclk
# Keycloak synthetic federation test IdP (programmatic-arm token minter)

# Core Service Definition
RBRN_MONIKER=fdkyclk
RBRN_DESCRIPTION="Keycloak synthetic federation test IdP — mints programmatic-arm OIDC id_tokens"
RBRN_RUNTIME=docker

# Vessel Source Configuration (boring tether sentry; Keycloak in the bottle slot)
RBRN_SENTRY_VESSEL=rbev-sentry-deb-tether
RBRN_BOTTLE_VESSEL=rbev-bottle-fdkyclk
# Hallmarks are driven in by kludge (rbw-cKS / rbw-cKB); these are pre-kludge placeholders.
RBRN_SENTRY_HALLMARK=
RBRN_BOTTLE_HALLMARK=

# Service Readiness (Keycloak boot + realm import needs warmup)
RBRN_BOTTLE_READINESS_DELAY_SEC=25

# Port Service Configuration (host 8088 -> enclave Keycloak 8080)
RBRN_ENTRY_MODE=rbnne_enabled
RBRN_ENTRY_PORT_WORKSTATION=8088
RBRN_ENTRY_PORT_ENCLAVE=8080

# Network Uplink Configuration (Keycloak is self-contained; no egress needed)
RBRN_UPLINK_PORT_MIN=10000
RBRN_UPLINK_DNS_MODE=rbnne_disabled
RBRN_UPLINK_ACCESS_MODE=rbnne_disabled
RBRN_UPLINK_ALLOWED_CIDRS=0.0.0.0/0
RBRN_UPLINK_ALLOWED_DOMAINS=localhost

# Network Configuration (fresh enclave subnet; 10.242.0-4.0 already taken)
RBRN_ENCLAVE_BASE_IP=10.242.5.0
RBRN_ENCLAVE_NETMASK=24
RBRN_ENCLAVE_SENTRY_IP=10.242.5.2
RBRN_ENCLAVE_BOTTLE_IP=10.242.5.3

# eof
