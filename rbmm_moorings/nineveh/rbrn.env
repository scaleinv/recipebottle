# Recipe Bottle Nameplate - nineveh
# Local Kroki-core diagram render server (trial)

# Core Service Definition
RBRN_MONIKER=nineveh
RBRN_DESCRIPTION="Local Kroki-core diagram render server (graphviz, plantuml, d2)"
RBRN_RUNTIME=docker

# Vessel Source Configuration (GAR vessels)
RBRN_SENTRY_VESSEL=rbev-sentry-deb-tether
RBRN_BOTTLE_VESSEL=rbev-bottle-kroki
RBRN_SENTRY_HALLMARK=
# Bottle hallmark produced by ordain-bind of rbev-bottle-kroki (rbw-fO), which
# mirrored kroki into GAR; image+about+vouch present under this hallmark.
RBRN_BOTTLE_HALLMARK=

# Service Readiness (kroki is JVM-based — needs warmup before responding)
RBRN_BOTTLE_READINESS_DELAY_SEC=30

# Port Service Configuration
RBRN_ENTRY_MODE=rbnne_enabled
RBRN_ENTRY_PORT_WORKSTATION=8006
RBRN_ENTRY_PORT_ENCLAVE=8000

# Network Uplink Configuration
RBRN_UPLINK_PORT_MIN=10000
RBRN_UPLINK_DNS_MODE=rbnne_disabled
RBRN_UPLINK_ACCESS_MODE=rbnne_disabled
RBRN_UPLINK_ALLOWED_CIDRS=0.0.0.0/0
RBRN_UPLINK_ALLOWED_DOMAINS=localhost

# Network Configuration
RBRN_ENCLAVE_BASE_IP=10.242.6.0
RBRN_ENCLAVE_NETMASK=24
RBRN_ENCLAVE_SENTRY_IP=10.242.6.2
RBRN_ENCLAVE_BOTTLE_IP=10.242.6.3

# eof
